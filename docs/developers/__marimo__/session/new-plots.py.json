      "code_hash": "839469ac9a3c533a758360b2ae1456de",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"drawing-edges\">Drawing edges</h2>\n<span class=\"paragraph\">For edges, we could take advantage of hive plot's lines.\nThat would make the chart look interesting...\nlike one of those arts and crafts tapestries we might have made when we were younger.</span></span>"
          }
        }
      ],
      "console": []
    },
    {
      "id": "DnEU",
      "code_hash": "2b331e183df51a899b41c4dd380b3c9e",
