      "console": []
    },
    {
      "id": "Vxnm",
      "code_hash": "ff3e17767bfca3cf290f44db83da72c5",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"custom-panels\">Custom panels</h2>\n<span class=\"paragraph\">While there are plot-specific faceting APIs,\nyou can use the building blocks in there to compose your own.</span>\n<span class=\"paragraph\">In this example,\nwe'll show you how to create a facet where we show\nonly edges that are associated with a particular group of nodes.\nFor this, the key function to use is <code>node_group_edges</code>,\nwhich yields graphs that contains edges attached to a particular group,\nas well as the group itself.</span></span>"
          }
        }
      ],
      "console": []
    },
